@model AzureCinemaHub.Models.Movie

@{
    ViewData["Title"] = "Додати новий фільм";
}

<!-- Підключення Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        background-color: #121216;
        color: #f3f4f6;
    }

    /* Кнопка "Назад" */
    .btn-back {
        background: rgba(244, 114, 182, 0.1);
        color: #f472b6;
        border: 1px solid rgba(244, 114, 182, 0.3);
        border-radius: 0.75rem;
        padding: 0.5rem 1.25rem;
        font-weight: 500;
        transition: all 0.2s ease;
    }

        .btn-back:hover {
            background: #f472b6;
            color: #121216;
            box-shadow: 0 0 15px rgba(244, 114, 182, 0.4);
        }

    /* Картка форми */
    .form-card {
        background: #18181c;
        border: 1px solid rgba(244, 114, 182, 0.2);
        border-radius: 1.25rem;
        padding: 2.5rem;
        box-shadow: 0 20px 30px -10px rgba(0, 0, 0, 0.5), 0 0 20px rgba(244, 114, 182, 0.05);
    }

    /* Стилізація полів вводу */
    .form-label {
        color: #f472b6;
        font-weight: 600;
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }

    .form-control {
        background-color: #121216;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #ffffff;
        border-radius: 0.75rem;
        padding: 0.75rem 1rem;
        transition: all 0.2s ease;
    }

        .form-control:focus {
            background-color: #121216;
            border-color: #f472b6;
            color: #ffffff;
            box-shadow: 0 0 10px rgba(244, 114, 182, 0.3);
            outline: none;
        }

        .form-control::placeholder {
            color: #6b7280;
        }

    /* Рожева кнопка відправки */
    .btn-submit {
        background: linear-gradient(135deg, #f472b6 0%, #ec4899 100%);
        color: #ffffff;
        border: none;
        border-radius: 0.75rem;
        font-weight: 600;
        padding: 0.8rem 1.75rem;
        transition: all 0.2s ease;
    }

        .btn-submit:hover {
            background: linear-gradient(135deg, #f472b6 0%, #db2777 100%);
            color: #ffffff;
            box-shadow: 0 0 20px rgba(244, 114, 182, 0.5);
        }
</style>

<div class="container py-4" style="max-width: 720px;">
    <!-- Верхня кнопка "Назад" -->
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-back d-inline-flex align-items-center gap-2">
            <i class="bi bi-arrow-left"></i> Назад до каталогу
        </a>
    </div>

    <!-- Картка з формою -->
    <div class="form-card">
        <h2 class="fw-bold text-white mb-4 d-flex align-items-center gap-2">
            <i class="bi bi-cloud-upload text-pink" style="color: #f472b6;"></i> Завантажити новий фільм
        </h2>

        <form asp-action="Create" enctype="multipart/form-data" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Назва -->
            <div class="mb-4">
                <label asp-for="Title" class="form-label">
                    <i class="bi bi-type me-1"></i> Назва фільму
                </label>
                <input asp-for="Title" class="form-control" placeholder="Введіть назву фільму..." required />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <!-- Опис -->
            <div class="mb-4">
                <label asp-for="Description" class="form-label">
                    <i class="bi bi-text-paragraph me-1"></i> Опис
                </label>
                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Короткий опис сюжету..." required></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <!-- Файл -->
            <div class="mb-4">
                <label class="form-label">
                    <i class="bi bi-file-earmark-play me-1"></i> Відеофайл (.mp4)
                </label>
                <input type="file" name="videoFile" class="form-control" accept="video/*" required />
            </div>

            <!-- Кнопка -->
            <div class="pt-2">
                <button type="submit" class="btn btn-submit d-inline-flex align-items-center gap-2 w-100 justify-content-center fs-6">
                    <i class="bi bi-check-circle-fill"></i> Зберегти та завантажити
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}